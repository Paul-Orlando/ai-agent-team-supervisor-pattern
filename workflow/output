Key Features Implemented:

Data Upload and Cleaning Endpoints
Statistical Analysis Functions
javascript
// backend/routes/dataRoutes.js
const express = require('express');
const multer = require('multer');
const router = express.Router();
const { processDataFile } = require('../controllers/dataController');

const upload = multer({ dest: 'uploads/' });

router.post('/upload', upload.single('datafile'), processDataFile);

module.exports = router;

// backend/controllers/dataController.js
const fs = require('fs');
const csv = require('csv-parser');

const processDataFile = (req, res) => {
    const results = [];
    
    fs.createReadStream(req.file.path)
        .pipe(csv())
        .on('data', (data) => results.push(data))
        .on('end', () => {
            // Data cleaning example (remove duplicates)
            const cleanedData = [...new Set(results.map(JSON.stringify))].map(JSON.parse);
            res.json(cleanedData);
        });
};

module.exports = { processDataFile };
